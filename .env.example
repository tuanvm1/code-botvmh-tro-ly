# ================================================================
# FILE CẤU HÌNH BÍ MẬT — chép file này thành ".env" rồi điền vào
# (Claude sẽ giúp bạn lấy từng giá trị, không cần bạn tự tìm)
# ================================================================

# --- TELEGRAM (bảng điều khiển) ---
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=
# Telegram của BẠN (chỉ mình bạn điều khiển được bot). Claude lấy giúp.
TELEGRAM_OWNER_CHAT_ID=

# --- CLAUDE / ANTHROPIC (AI viết bài + phân tích) ---
# Lấy tại console.anthropic.com (nạp trước tối thiểu ~5 USD)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- FACEBOOK (đăng bài + quảng cáo + báo cáo Trang) ---
FB_API_VERSION=v25.0
# Page access token loại KHÔNG hết hạn (Claude lấy giúp qua Graph API Explorer)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# System User token (Business Manager) cho quảng cáo — KHÔNG hết hạn
FB_AD_ACCOUNT_ID=          # dạng act_1234567890
FB_ADS_ACCESS_TOKEN=

# --- CẤU HÌNH DOANH NGHIỆP (để AI viết đúng giọng) ---
BUSINESS_NAME=Sân cầu lông VMH
BUSINESS_DESC=Sân cầu lông chất lượng, cho thuê theo giờ, có căng-tin và chỗ để xe.
BRAND_TONE=Thân thiện, gần gũi, khích lệ chơi thể thao; xưng "sân mình" với khách.

# --- CHỐT AN TOÀN QUẢNG CÁO ---
# Trần ngân sách/ngày (VND) mà bot KHÔNG BAO GIỜ được đặt vượt qua
ADS_MAX_DAILY_BUDGET_VND=500000
# Ngưỡng dữ liệu tối thiểu trước khi AI dám gợi ý tắt chiến dịch
ADS_MIN_SPEND_FOR_ADVICE_VND=100000
ADS_MIN_DAYS_FOR_ADVICE=2

# --- GIỜ GIẤC (múi giờ VN) ---
TZ=Asia/Ho_Chi_Minh
DAILY_ADS_REPORT_HOUR=8       # báo cáo quảng cáo mỗi sáng 8h
DAILY_POST_DRAFT_HOUR=7       # gửi bản nháp bài mỗi sáng 7h
WEEKLY_PAGE_REPORT_DOW=mon    # báo cáo Trang: thứ Hai hàng tuần
